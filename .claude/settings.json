{
  "permissions": {
    "allow": [
      "Bash(pytest:*)",
      "Bash(alembic upgrade head)",
      "Bash(alembic check)",
      "Bash(npm test)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)"
    ],
    "deny": [
      "Read(backend/.env)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  }
}
