# Zauberkoch — Backend-Konfiguration
# Kopie als backend/.env (dev) bzw. /opt/zauberkoch-api/.env (prod, mode 640).
# NIEMALS eine echte .env committen.

# --- Umgebung ---
ZK_ENV=dev                        # dev | prod (prod: keine OpenAPI-Docs, Secure-Cookies)
ZK_BASE_URL=http://localhost:5173 # Öffentliche URL (prod: https://zauberkoch.de)
ZK_PORT=8742                      # Backend-Port (loopback hinter nginx)
ZK_DB_PATH=data/zauberkoch.db     # SQLite-Datei (relativ zu backend/ bzw. /opt/zauberkoch-api/)

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...      # NUR server-seitig, nie ins Frontend
ANTHROPIC_MODEL=claude-sonnet-5   # Modell-ID, austauschbar
ANTHROPIC_MAX_TOKENS=8000         # Output-Budget pro Generierung

# --- Google OAuth (bestehender Client, siehe docs/GOOGLE-OAUTH.md) ---
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
# Redirect-URI wird aus ZK_BASE_URL abgeleitet: {ZK_BASE_URL}/api/v1/auth/callback

# --- Sessions & Security ---
SESSION_SECRET=                   # openssl rand -hex 32
SESSION_TTL_HOURS=720             # 30 Tage

# --- Zugang & Limits ---
OPEN_SIGNUP=false                 # false: nur E-Mails aus Allowlist (scripts/allowlist)
DAILY_LIMIT_PER_USER=20           # Generierungen pro User pro Tag
DAILY_LIMIT_GLOBAL=200            # Generierungen gesamt pro Tag (Kostenschutz)
ZK_DEV_LOGIN=false                # true NUR lokal: Fake-Login ohne Google-Client (in prod hart deaktiviert)
